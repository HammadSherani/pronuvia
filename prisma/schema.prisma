generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SALES_REP
  PHYSICIAN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalesRepresentative {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  firstName         String
  lastName          String
  email             String   @unique
  website           String?
  password          String
  phone             String?
  ordersCount       Int      @default(0)
  commission        Float    @default(0)
  walletBalance     Float    @default(0)
  billingAddress    String?
  shippingAddress   String?
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  swiftCode         String?
  routingNumber     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  passwordResetToken  String?
  passwordResetExpiry DateTime?

  physicians  PartneringPhysician[]
  orderItems  Order[]
}

model Category {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  slug          String        @unique
  description   String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  subCategories SubCategory[]
  products      Product[]
}

model SubCategory {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  categoryId  String    @db.ObjectId
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Product {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  slug           String        @unique
  description    String?
  image          String?
  imageGallery   String[]
  salePrice      Float
  costPrice      Float
  compareAtPrice Float?
  quantity       Int           @default(0)
  discount       Float         @default(0)
  sku            String        @unique
  gtin           String?
  weight         Float?
  weightUnit     String        @default("kg")
  tags           String[]
  variants       Json[]
  status         ProductStatus @default(ACTIVE)
  categoryId     String?       @db.ObjectId
  subCategoryId  String?       @db.ObjectId
  category       Category?     @relation(fields: [categoryId], references: [id])
  subCategory    SubCategory?  @relation(fields: [subCategoryId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model PartneringPhysician {
  id                  String         @id @default(auto()) @map("_id") @db.ObjectId
  isApproved          ApprovalStatus @default(PENDING)
  firstName           String
  lastName            String
  email               String         @unique
  password            String
  aictherapy          String?
  license             String?
  websiteLink         String?
  addressOne          String?
  addressTwo          String?
  city                String?
  state               String?
  zipCode             String?
  country             String?
  phone               String?
  officeContactNumber String?
  fax                 String?
  nameOfPractice      String?
  yearsInPractice     Int?
  fieldsOfSpeciality  String[]
  commission          Float          @default(0)
  uplineCommission    Float          @default(0)
  salesRepNote        String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  bankName            String?
  bankAccountNumber   String?
  bankAccountName     String?
  swiftCode           String?
  routingNumber       String?
  walletBalance       Float          @default(0)
  ordersCount         Int            @default(0)
  addedByRole         Role
  addedByAdminId      String?        @db.ObjectId
  salesRepId          String?        @db.ObjectId
  salesRep            SalesRepresentative? @relation(fields: [salesRepId], references: [id])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  orderItems  Order[]
}

model CatalogDocument {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  fileName   String
  fileUrl    String
  fileSize   Int
  uploadedBy String   @db.ObjectId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

model Order {
  id                        String               @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber               String               @unique

  physicianId               String?              @db.ObjectId
  physician                 PartneringPhysician? @relation(fields: [physicianId], references: [id])

  salesRepId                String?              @db.ObjectId
  salesRep                  SalesRepresentative? @relation(fields: [salesRepId], references: [id])

  items                     Json[]

  subtotal                  Float
  total                     Float

  // Rates snapshotted at order creation — never recalculated on rate changes
  salesRepCommissionRate    Float                @default(0)
  salesRepCommissionAmount  Float                @default(0)
  physicianCommissionRate   Float                @default(0)
  physicianCommissionAmount Float                @default(0)

  status                    OrderStatus          @default(PENDING)
  commissionPaid            Boolean              @default(false)
  billingAddress            String?
  shippingAddress           String?
  shippingRate              Float                @default(0)
  shippingCarrier           String?
  trackingNumber            String?
  estimatedDelivery         DateTime?
  paymentMethod             String?
  paymentStatus             String?
  transactionId             String?
  stripePaymentIntentId     String?
  notes                     String?

  couponCode                String?
  couponId                  String?              @db.ObjectId
  discountAmount            Float                @default(0)

  placedByAdmin             Boolean              @default(false)

  // Return / clawback fields
  returnedAt                DateTime?
  returnReason              String?
  returnedItems             Json?                // null = full return, array of item indexes = partial
  returnedTotal             Float?               // $ value of returned items
  salesRepClawback          Float?               // deducted from sales rep wallet
  physicianClawback         Float?               // informational — physician has no wallet

  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
}

model Coupon {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  code           String    @unique
  description    String?
  discountType   String    @default("PERCENTAGE")
  discountValue  Float
  minOrderAmount Float?
  maxUses        Int?
  usedCount      Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  applicableTo   String    @default("ALL")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Shipment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId        String   @db.ObjectId
  carrier        String
  carrierLabel   String
  service        String
  serviceCode    String
  trackingNumber String
  labelBase64    String?
  labelFormat    String   @default("PNG")
  fromAddress    Json
  toAddress      Json
  weightLbs      Float
  lengthIn       Float?
  widthIn        Float?
  heightIn       Float?
  cost           Float    @default(0)
  currency       String   @default("USD")
  status         String   @default("created")
  shipDate       DateTime @default(now())
  createdAt      DateTime @default(now())
}

model OrderNote {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String   @db.ObjectId
  type      String   // "private" | "customer"
  content   String
  createdAt DateTime @default(now())
}

model WalletTransaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  userRole    Role
  amount      Float
  type        String
  description String?
  orderId     String?  @db.ObjectId
  balance     Float
  createdAt   DateTime @default(now())
}

enum WithdrawStatus {
  PENDING
  APPROVED
  REJECTED
}

model WithdrawRequest {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  userId    String         @db.ObjectId
  userRole  Role
  amount    Float
  status    WithdrawStatus @default(PENDING)
  note      String?
  adminNote String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Banner {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  imageUrl    String
  linkUrl     String?
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Blog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String    @unique
  excerpt     String?
  content     String?
  imageUrl    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WebsiteBanner {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  subtitle    String?
  buttonText  String?
  imageUrl    String
  linkUrl     String?
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ShippingMethod {
  FLAT
  FREE
  LOCAL_PICKUP
}

model ShippingRate {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  continent   String
  country     String         // ISO 2-letter code e.g. "US"
  countryName String         // Full name e.g. "United States"
  // empty = country-wide rule; populated = applies only to these state codes
  states      String[]
  stateNames  String[]
  method      ShippingMethod
  cost        Float          @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}
